{
  "compilerOptions": {
    "target": "esnext",
    "lib": ["es2022", "dom", "webworker"],
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "allowJs": true,
    "checkJs": true,
    "noEmit": true,
    "strict": true,
    "types": ["node", "webpack/module"],
    "skipDefaultLibCheck": true,
    "esModuleInterop": true
  },
  "include": ["./client-src/**/*"]
}
